{
  "name": "@adrianmross/oci-idm",
  "version": "0.5.0",
  "description": "Plan OCI Identity Domains apps, grants, and token-helper handoffs",
  "license": "MIT",
  "homepage": "https://github.com/adrianmross/oci-identity-apps#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adrianmross/oci-identity-apps.git"
  },
  "bugs": {
    "url": "https://github.com/adrianmross/oci-identity-apps/issues"
  },
  "type": "commonjs",
  "bin": {
    "oci-idm": "npm/bin/oci-idm.js",
    "oci-identity-apps": "npm/bin/oci-identity-apps.js"
  },
  "files": [
    "cmd/",
    "internal/",
    "go.mod",
    "LICENSE",
    "README.md",
    "npm/bin/oci-idm.js",
    "npm/bin/oci-identity-apps.js",
    "npm/scripts/build.js"
  ],
  "scripts": {
    "build:npm": "node npm/scripts/build.js",
    "test:npm": "node npm/scripts/build.js && node npm/bin/oci-identity-apps.js version",
    "publish:github": "npm publish --registry https://npm.pkg.github.com",
    "publish:npmjs": "npm publish --access public --registry https://registry.npmjs.org",
    "postinstall": "node npm/scripts/build.js"
  },
  "engines": {
    "node": ">=18"
  }
}
